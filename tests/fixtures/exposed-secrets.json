{
  "mcpServers": {
    "stripe-bad": {
      "command": "node",
      "args": ["./mcp-stripe.js"],
      "env": {
        "STRIPE_KEY": "__STRIPE_LIVE_KEY_PLACEHOLDER__",
        "GITHUB_TOKEN": "__GITHUB_PAT_PLACEHOLDER__"
      }
    },
    "ok-server": {
      "command": "node",
      "args": ["./mcp-ok.js"],
      "env": {
        "API_KEY": "${MY_API_KEY}",
        "ENDPOINT": "https://api.example.com"
      }
    }
  }
}
